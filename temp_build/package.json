{
  "name": "terrasim",
  "version": "0.4.0",
  "description": "TerraSim Geotechnical FEA software",
  "author": "Dahar Engineer",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "electron:dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "python -m PyInstaller backend/build_exe.spec --noconfirm",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder"
  },
  "dependencies": {
    "@deck.gl/core": "^9.1.13",
    "@deck.gl/layers": "^9.1.13",
    "@deck.gl/react": "^9.1.13",
    "@types/d3": "^7.4.3",
    "@types/react-map-gl": "^6.1.7",
    "d3": "^7.9.0",
    "d3-contour": "^4.0.2",
    "react-map-gl": "^8.0.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.daharengineer.terrasim",
    "productName": "TerraSim",
    "icon": "frontend/public/TerraSim.png",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "zip"
    }
  }
}